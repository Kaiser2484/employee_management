generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  hr
  manager
  team_lead
  employee
}

enum LeaveStatus {
  pending
  approved
}

model Department {
  id    String @id
  name  String
  teams Team[]
  users User[]
}

model Team {
  id           String @id
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]
}

model User {
  id           String   @id
  fullName     String
  email        String?  @unique
  passwordHash String?
  role         Role
  departmentId String?
  teamId       String?
  department   Department? @relation(fields: [departmentId], references: [id])
  team         Team?       @relation(fields: [teamId], references: [id])
  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id         String      @id
  employeeId String
  fromDate   DateTime
  toDate     DateTime
  status     LeaveStatus @default(pending)
  employee   User        @relation(fields: [employeeId], references: [id])
}
