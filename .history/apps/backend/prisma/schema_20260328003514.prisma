generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  hr
  manager
  team_lead
  employee
}

enum LeaveStatus {
  pending
  approved
  rejected
}

model Department {
  id    String @id
  name  String
  teams Team[]
  users User[]
}

model Team {
  id           String @id
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]
}

model User {
  id           String   @id
  fullName     String
  degree       String   @default("")
  email        String?  @unique
  passwordHash String?
  role         Role
  departmentId String?
  teamId       String?
  gender         String?
  dateOfBirth    DateTime?
  startDate      DateTime?
  nationalId     String?
  address        String?
  employeeStatus String?
  jobCategory    String?
  jobTitle       String?
  photoUrl       String?
  department   Department? @relation(fields: [departmentId], references: [id])
  team         Team?       @relation(fields: [teamId], references: [id])
  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id         String      @id
  employeeId String
  leaveType  String      @default("annual")
  fromDate   DateTime
  toDate     DateTime
  status     LeaveStatus @default(pending)
  reason     String?
  attachment String?
  createdAt  DateTime    @default(now())
  employee   User        @relation(fields: [employeeId], references: [id])
}

